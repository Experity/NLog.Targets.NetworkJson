<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net462;net48;netstandard2.0;net10.0</TargetFrameworks>
    <AssemblyName>NLog.Targets.NetworkJSON</AssemblyName>
    <RootNamespace>NLog.Targets.NetworkJSON</RootNamespace>
    <PackageId>NLog.Targets.NetworkJson</PackageId>
    <Description>NLog Target for JSON Communication via TCP or UDP with Guaranteed Delivery support</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" Condition="Exists('..\README.md')" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" />
    <!-- Explicit bundle override: 3.x uses SourceGear.sqlite3 instead of vulnerable SQLitePCLRaw.lib.e_sqlite3 -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" />
    <PackageReference Include="SourceGear.sqlite3" />
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="NLog" />
  </ItemGroup>

  <!-- System.ComponentModel.DataAnnotations is not auto-referenced in SDK-style projects -->
  <ItemGroup>
    <PackageReference Include="System.ComponentModel.Annotations" />
  </ItemGroup>

</Project>